* 3.*
* 4.*
*\ 2.*
*\ 3.*
*\ 4.*
*/__pycache__\ */
*/__pycache__\ 2/
*/__pycache__\ 3/

# ─── Incremental development backups ─────────────────────────────────────────
# We keep the canonical benchmark CSVs; backups are local-only.
results/tables/benchmark_*_backup_*.csv
results/tables/benchmark_*_backup_threshold_*.csv

# ─── Sandbox / scratch notebooks ─────────────────────────────────────────────
# Development notebooks live in sandbox/; only entrega_final.ipynb is the deliverable.
notebooks/sandbox/

